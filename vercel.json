{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "^/$",
      "status": 302,
      "headers": { "Location": "/frontend/index.html" }
    },
    {
      "src": "/frontend/(.*)",
      "dest": "/frontend/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/((?!frontend/).*)",
      "dest": "/index.html"
    }
  ]
}
